{% extends 'base.html.twig' %}

{% block title %}Galeries — Nexo{% endblock %}

{% block body %}
    <div class="py-5 mb-5 border-bottom">
        <h1 class="display-3 fw-bold" style="letter-spacing: -0.04em;">Galeries</h1>
        <p class="lead text-muted">Une immersion visuelle dans nos projets et notre univers.</p>
    </div>

    <div class="row g-4">
        {% for galerie in galeries %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm overflow-hidden group">
                    <div class="position-relative">
                        {% if galerie.images|length > 0 %}
                            <img src="{{ asset(galerie.images[0].url) }}" 
                                 class="card-img-top transition-all" 
                                 alt="{{ galerie.nom }}"
                                 style="height: 300px; object-fit: cover;">
                        {% else %}
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 300px;">
                                <span class="text-muted">Aucun aperçu</span>
                            </div>
                        {% endif %}
                        <div class="position-absolute bottom-0 start-0 p-4 w-100 bg-gradient-dark text-white">
                            <span class="badge bg-white text-dark mb-2">{{ galerie.images|length }} photos</span>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <h2 class="h4 fw-bold mb-2">
                            <a href="{{ path('galerie_show', {id: galerie.id}) }}" class="text-decoration-none text-dark stretched-link">
                                {{ galerie.nom }}
                            </a>
                        </h2>
                        <p class="text-muted small mb-0">{{ galerie.description|default('Découvrez cette galerie photo.') }}</p>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <div class="alert bg-light border-0 text-muted">
                    Aucune galerie n'est disponible pour le moment.
                </div>
            </div>
        {% endfor %}
    </div>

    <style>
        .bg-gradient-dark {
            background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
        }
        .group:hover .card-img-top {
            transform: scale(1.05);
        }
        .transition-all { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
    </style>
{% endblock %}
